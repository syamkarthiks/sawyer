# ─── Sawyer Bot — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values before running locally.
# For Render/Koyeb: set these in the platform's dashboard Environment section.

# Command prefix (e.g. . for .menu, .ping)
PREFIX=.

# Your WhatsApp number with country code (no + or spaces)
OWNER_NUMBER=919888280858

# Bot display name
BOT_NAME=Sawyer Bot

# Your name (shown in menu)
OWNER_NAME=Syam

# HTTP server port (Render/Koyeb override this automatically)
PORT=3000

# Extra numbers that can use owner-only commands (comma separated)
SUDO_NUMBERS=919888280858

# Set to true to make bot respond ONLY to owner + sudo numbers
PRIVATE_MODE=false

# ─── Session ──────────────────────────────────────────────────────────────────
# SESSION_ID: Your Baileys session ID (get it from session pairing tools).
# Leave blank to use QR code scan on first run (local only).
# ⚠️ Required for Render/Koyeb deployment — without it the bot can't connect!
SESSION_ID=

# Where to store session files (defaults to ./session if blank)
# Use /tmp/sawyer-session for Render/Koyeb (ephemeral is fine — SESSION_ID handles reconnect)
SESSION_DIR=/tmp/sawyer-session
